{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Concrem Connect",
  "version": "0.1.0",
  "identifier": "br.com.concrem.connect",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Concrem Connect",
        "width": 1280,
        "height": 800,
        "minWidth": 390,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "theme": null
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Concrem Portas Premium",
    "copyright": "© 2026 Concrem",
    "category": "Business",
    "shortDescription": "Portal do Representante Concrem",
    "longDescription": "Concrem Connect — portal do representante para orçamentos, pedidos, acompanhamento, carteira de clientes e documentos financeiros.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
