# Supabase
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key_aqui

# Habilita dados mock (true = mock, false = Supabase real)
VITE_USE_MOCK=false

# Cloudflare Turnstile (chave pública — obter em dash.cloudflare.com)
# Deploy da Edge Function: supabase functions deploy verificar-turnstile --no-verify-jwt
VITE_TURNSTILE_SITE_KEY=
